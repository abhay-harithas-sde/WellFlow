{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "dist",
    "noEmit": false,
    "target": "ES2020",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true,
    "plugins": []
  },
  "include": [
    "server/**/*",
    "src/**/*",
    "lib/**/*"
  ],
  "exclude": [
    "node_modules",
    "app/**/*",
    "components/**/*",
    "hooks/**/*"
  ]
}
